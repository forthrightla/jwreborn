---
/**
 * Writing Listing Page
 * Lists all blog posts from the writing collection
 * Follows patterns from case-studies.astro
 */
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Get all writing posts, sorted by date (newest first)
const allPosts = await getCollection("writing");
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title="Writing - Josh Wright"
  currentNav="writing"
  description="Thoughts on design, product strategy, and the craft of building digital products."
>
  <section id="hero" class="block hero-block outer">
    <div class="inner">
      <div class="block-header">
        <h1 class="block-title">Thoughts on <strong>design</strong>, <strong>product</strong>, and the <strong>craft</strong><span class="accent-period">.</span></h1>
      </div>
    </div>
  </section>

  <main id="content" class="site-content">
    <section class="writing-block block outer">
      <div class="inner">
        <div class="block-content">
          <div class="writing-feed">
            {posts.map((post) => {
              const wordCount = post.body.split(/\s+/).length;
              const readingTime = Math.max(1, Math.ceil(wordCount / 220));
              const formattedDate = post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              });

              return (
                <article class="writing-card">
                  <a href={`/writing/${post.id}`} class="writing-card-link">
                    {post.data.heroImage && (
                      <div class="writing-card-image">
                        <picture>
                          <source srcset={`${post.data.heroImage}?format=avif`} type="image/avif" />
                          <source srcset={`${post.data.heroImage}?format=webp`} type="image/webp" />
                          <img
                            src={post.data.heroImage}
                            alt={post.data.title}
                            loading="lazy"
                          />
                        </picture>
                      </div>
                    )}
                    <div class="writing-card-content">
                      <div class="writing-card-meta">
                        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                        <span class="meta-separator">·</span>
                        <span>{readingTime} min read</span>
                      </div>
                      <h2 class="writing-card-title">{post.data.title}</h2>
                      {post.data.description && (
                        <p class="writing-card-description">{post.data.description}</p>
                      )}
                      <span class="writing-card-cta">
                        Read more
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                          <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .writing-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .writing-card {
    background: var(--color-bg);
    border: var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .writing-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .writing-card-link {
    display: flex;
    flex-direction: row;
    text-decoration: none;
    color: inherit;
  }

  .writing-card-image {
    flex-shrink: 0;
    width: 280px;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-surface);
  }

  .writing-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .writing-card:hover .writing-card-image img {
    transform: scale(1.03);
  }

  .writing-card-content {
    flex: 1;
    padding: var(--space-lg) var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .writing-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: "Funnel Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .meta-separator {
    opacity: 0.5;
  }

  .writing-card-title {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
  }

  .writing-card-description {
    font-family: "Funnel Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-base);
    /* Limit to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .writing-card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-family: "Funnel Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    transition: gap var(--transition-fast);
  }

  .writing-card:hover .writing-card-cta {
    gap: var(--space-xs);
  }

  .writing-card-cta svg {
    transition: transform var(--transition-fast);
  }

  .writing-card:hover .writing-card-cta svg {
    transform: translateX(2px);
  }

  /* Dark mode */
  :global([data-theme="dark"]) .writing-card {
    background: var(--color-surface);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .writing-card-link {
      flex-direction: column;
    }

    .writing-card-image {
      width: 100%;
      aspect-ratio: 16/9;
    }

    .writing-card-content {
      padding: var(--space-base) var(--space-lg);
    }

    .writing-card-title {
      font-size: var(--text-base);
    }
  }

  @media (max-width: 480px) {
    .writing-feed {
      gap: var(--space-lg);
    }

    .writing-card {
      border-radius: var(--radius-sm);
    }

    .writing-card-content {
      padding: var(--space-base);
    }

    .writing-card-title {
      font-size: var(--text-sm);
    }

    .writing-card-description {
      font-size: var(--text-xs);
      -webkit-line-clamp: 3;
    }
  }
</style>
