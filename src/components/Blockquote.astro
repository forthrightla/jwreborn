---
/**
 * Blockquote Component
 *
 * A simple pull quote for blog content. For quotes with attribution,
 * use FeaturedQuote.astro instead.
 *
 * Usage in MDX:
 *   <Blockquote>
 *     The difference between an expert and a novice is not just time spent,
 *     but how that time is structured.
 *   </Blockquote>
 *
 * With citation:
 *   <Blockquote cite="Anders Ericsson">
 *     Deliberate practice requires focused attention...
 *   </Blockquote>
 */

interface Props {
  cite?: string;
}

const { cite } = Astro.props;
---

<blockquote class="blockquote">
  <div class="blockquote-content">
    <slot />
  </div>
  {cite && (
    <footer class="blockquote-footer">
      <cite>{cite}</cite>
    </footer>
  )}
</blockquote>

<style>
  .blockquote {
    position: relative;
    margin: var(--space-xl) 0;
    padding: var(--space-lg) var(--space-xl);
    padding-left: var(--space-xl);
    background: var(--color-surface);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-none);
  }

  .blockquote::before {
    content: "\201C";
    position: absolute;
    top: var(--space-sm);
    left: var(--space-base);
    font-size: 2.5rem;
    font-family: Georgia, "Times New Roman", serif;
    color: var(--color-accent);
    line-height: 1;
    opacity: 0.6;
  }

  .blockquote-content {
    padding-left: var(--space-lg);
    font-family: "IBM Plex Serif", Georgia, serif;
    font-style: italic;
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .blockquote-content :global(p) {
    margin: 0;
  }

  .blockquote-content :global(p + p) {
    margin-top: var(--space-base);
  }

  .blockquote-footer {
    margin-top: var(--space-base);
    padding-left: var(--space-lg);
  }

  .blockquote-footer cite {
    font-family: "Funnel Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    font-style: normal;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .blockquote-footer cite::before {
    content: "\2014\00a0";
  }

  /* Dark mode */
  :global([data-theme="dark"]) .blockquote {
    background: var(--color-surface);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .blockquote {
      margin: var(--space-lg) 0;
      padding: var(--space-base) var(--space-lg);
    }

    .blockquote::before {
      font-size: 2rem;
      left: var(--space-sm);
    }

    .blockquote-content {
      padding-left: var(--space-base);
    }

    .blockquote-footer {
      padding-left: var(--space-base);
    }
  }

  @media (max-width: 480px) {
    .blockquote {
      padding: var(--space-sm) var(--space-base);
    }

    .blockquote::before {
      display: none;
    }

    .blockquote-content {
      padding-left: 0;
      font-size: var(--text-xs);
    }

    .blockquote-footer {
      padding-left: 0;
    }
  }
</style>
